{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/next"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ],
  "env": {
    "NEXT_PUBLIC_CONTRACT_ADDRESS": "0x3914fa9a5117392fb8e4a39a572c135d6112bda4281a49901426a173d2629b70",
    "NEXT_PUBLIC_APTOS_NETWORK": "testnet"
  }
}